<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginStart="30dp"
    android:layout_marginEnd="30dp"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- buttons -->
    <!-- !View.GONE & View.VISIBLE-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_exerciseA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="goExerciseA"
            android:text="Go Exercise A" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Made with Firebase Real Time Database" />

        <View
            android:layout_width="match_parent"
            android:layout_height="50dp" />

        <Button
            android:id="@+id/btn_exerciseB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="goExerciseB"
            android:text="Go Exercise B" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="JSON API interaction with Retrofit" />

    </LinearLayout>
</LinearLayout>